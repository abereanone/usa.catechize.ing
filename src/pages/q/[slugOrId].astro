---
import { getPublishedQuestions } from "@/lib/questions";

export function getStaticPaths() {
  const seen = new Set();

  return getPublishedQuestions().flatMap((question) => {
    const entries = [{ params: { slugOrId: question.slug } }];
    if (typeof question.id === "number") {
      entries.push({ params: { slugOrId: String(question.id) } });
      question.groupCodes.forEach((code) => {
        entries.push({ params: { slugOrId: `${code}${question.id}` } });
      });
    }

    return entries.filter((entry) => {
      const key = entry.params.slugOrId;
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
  });
}

const { slugOrId } = Astro.params;

if (!slugOrId) {
  throw new Error("Question alias route requires a slug or id.");
}

return Astro.redirect(`/questions/${slugOrId}`, 301);
---
